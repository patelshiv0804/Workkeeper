## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This .gitignore file for .NET projects is based on the official Microsoft 
## recommendations found at https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][In][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache files, configuration, etc.
.vs/
[Tt]est[Rr]esults/
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Roslyn cache directories
.build-analyzer/

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Windows image-cache files
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on separate drives
$RECYCLE.BIN/

# VS Code folders and files
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# AspNet5
wwwroot/lib/

# Web tools
.ntvs_analysis.dat
node_modules/

# Silverlight project user settings
*.vbproj.user
*.csproj.user
*.sqlproj.user
*.wwp
*.Cache
*.StyleCop

# MSTest test results
TestResults/
[Tt]est[Rr]esults/

# NUnit test results
TestResult.xml
nunit-agent.log

# Entity Framework Core
# (Uncomment if you don't want to track migrations)
# Migrations/

# AppSettings (Uncomment if you want to exclude secrets)
# appsettings.json
# appsettings.Development.json

# User secrets
secrets.json

# Common .NET temporary files
*.tmp
*.bak
*.swp
*.log
